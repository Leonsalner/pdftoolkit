{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Toolkit",
  "version": "1.2.0",
  "identifier": "com.leon.pdf-toolkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Toolkit",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://localhost:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/gs",
      "bin/tesseract",
      "bin/qpdf",
      "bin/llama-server"
    ],
    "resources": [
      "tessdata/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
