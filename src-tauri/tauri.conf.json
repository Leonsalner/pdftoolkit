{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Toolkit",
  "version": "2.0.0",
  "identifier": "com.leon.pdf-toolkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Toolkit",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://localhost:*;"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://leonsalner.github.io/pdftoolkit/update.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZEQTlDOEJBODJDNjIzM0UKUldRK0k4YUN1c2lwYmRsR09ES1VLUVJ5c3h2VmMxVmtYNE41Y0d1eTAwaUFKUmdlT1U2Z08xWUUK,
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/gs",
      "bin/tesseract",
      "bin/qpdf"
    ],
    "resources": [
      "tessdata/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 190, "y": 155 },
        "applicationFolderPosition": { "x": 470, "y": 155 }
      }
    }
  }
}
